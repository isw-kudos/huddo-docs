# =============================================================================
# Collab — environment configuration
# Fill in values below before running docker compose up
#
# Required: APP_URI, APP_HOST, IMAGE_TAG, plus credentials in each section.
# =============================================================================

IMAGE_TAG=YYYY-mm-dd

# -----------------------------------------------------------------------------
# Public URL  [required]
# APP_URI:  full base URL, no trailing slash.
# APP_HOST: hostname only (no protocol).
# -----------------------------------------------------------------------------
APP_URI=https://collab.example.com
APP_HOST=collab.example.com


# -----------------------------------------------------------------------------
# MongoDB  [required]
# -----------------------------------------------------------------------------
MONGO_PASSWORD=changeme


# -----------------------------------------------------------------------------
# S3 / SeaweedFS  [required]
# -----------------------------------------------------------------------------
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme


# -----------------------------------------------------------------------------
# SocketCluster  [required]
# -----------------------------------------------------------------------------
SOCKET_CLUSTER_SECRET=changeme


# -----------------------------------------------------------------------------
# HCL Connections OAuth  [required for Connections deployments]
# -----------------------------------------------------------------------------
CONNECTIONS_NAME=HCL Connections
CONNECTIONS_URL=https://connections.example.com
CONNECTIONS_HOSTNAME=connections.example.com
CONNECTIONS_CLIENT_ID=collabClientId
CONNECTIONS_CLIENT_SECRET=changeme
# Comma-separated list of admin email addresses
CONNECTIONS_ADMINS='["admin@example.com"]'

# Optional — override default OAuth endpoints if using a custom setup
#CONNECTIONS_OAUTH_AUTHORIZE_URL=
#CONNECTIONS_OAUTH_TOKEN_URL=
#CONNECTIONS_OAUTH_SCOPE=

# Optional — Keycloak-based Connections
#CONNECTIONS_KEYCLOAK_URL=
#CONNECTIONS_KEYCLOAK_PATH=/auth
#CONNECTIONS_KEYCLOAK_REALM=connections


# -----------------------------------------------------------------------------
# HCL DX OAuth  [optional — alternative to Connections]
# -----------------------------------------------------------------------------
#DX_NAME=HCL DX
#DX_CLIENT_ID=
#DX_CLIENT_SECRET=
#DX_URL=https://dx.example.com
#DX_HOSTNAME=dx.example.com
#DX_ADMINS=admin@example.com


# -----------------------------------------------------------------------------
# HCL Domino OAuth  [optional]
# -----------------------------------------------------------------------------
#DOMINO_IAM_URL=https://iam.example.com
#DOMINO_IAM_CLIENT_ID=
#DOMINO_IAM_CLIENT_SECRET=
#DOMINO_REST_SCOPE=directorylookup
#DOMINO_PROTON_HOST=
#DOMINO_PROTON_PORT=1352
#DOMINO_ADMINS=admin@example.com
#DOMINO_AUTH_URL=
#DOMINO_CLIENT_ID=
#DOMINO_CLIENT_SECRET=
#DOMINO_AUTH_SCOPE=


# -----------------------------------------------------------------------------
# Microsoft AD FS  [optional]
# -----------------------------------------------------------------------------
#MSAD_NAME=Microsoft AD
#MSAD_FS_URL=https://adfs.example.com
#MSAD_CLIENT_ID=
#MSAD_CLIENT_SECRET=
#MSAD_ADMINS=admin@example.com
#MSAD_LDAP_URL=ldap://adfs.example.com
#MSAD_LDAP_BIND_DN=
#MSAD_LDAP_BIND_PASSWORD=
#MSAD_LDAP_BASE_DN=